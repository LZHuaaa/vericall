# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: comma-separated pool for automatic rotation on 429/quota
# IMPORTANT: use keys from different Google AI Studio projects to get separate quotas.
GEMINI_API_KEYS=key_project_a,key_project_b,key_project_c

# Firebase (optional - for production)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CREDENTIALS_PATH=C:\absolute\path\to\serviceAccountKey.json

# Twilio VOIP (for demo)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# App Settings
DEBUG=true
PORT=5000
