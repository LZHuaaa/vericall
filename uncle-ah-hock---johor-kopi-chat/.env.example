# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Optional backend override (defaults to http://localhost:5000/api)
VITE_BACKEND_URL=http://localhost:5000/api

# Optional Firebase web config (enables Firestore realtime sync primary path)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=vericall-malaysia.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=vericall-malaysia
VITE_FIREBASE_STORAGE_BUCKET=vericall-malaysia.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional call-audio relay config
VITE_CALL_AUDIO_RELAY_ENABLED=true
VITE_CALL_AUDIO_WS_PORT=8765
# Example: ws://127.0.0.1:8765
VITE_CALL_AUDIO_WS_URL=
